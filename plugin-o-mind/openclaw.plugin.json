{
  "id": "o-mind",
  "name": "O-Mind",
  "version": "1.0.0",
  "description": "私有化部署的本地记忆服务 - 替代 mem9 的自建方案",
  "author": "O-Mind Team",
  "homepage": "https://gitlab.bjhzsk.cn/develop/o-mind",
  "platform": "openclaw",
  "dependencies": [],
  "keywords": ["memory", "persistent", "local", "o-mind"],
  "configSchema": {
    "memoryServerUrl": {
      "type": "string",
      "default": "http://localhost:8000",
      "description": "O-Mind API 服务器地址"
    },
    "apiKey": {
      "type": "string", 
      "default": "default",
      "description": "API Key"
    }
  },
  "tools": [
    "save_memory",
    "get_memories", 
    "search_memories",
    "get_stats"
  ]
}
